# Copy this to .env.local and fill in values. .env.local is gitignored.

# Optional: local path to a Google service-account JSON key. Use this when the
# workbook export URL requires authenticated access.
GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service-account.json

# Optional overrides (these defaults match production)
GOOGLE_SHEETS_WORKBOOK_URL=https://docs.google.com/spreadsheets/d/1IlCrI_aPESNDtPZ9629GSCjsCBhTakxbMP9eTlgzxUg/export?format=xlsx
GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/1IlCrI_aPESNDtPZ9629GSCjsCBhTakxbMP9eTlgzxUg/export?format=csv&gid=1179745250
RELIABILITY_DASH_PAGES_PROJECT=opsdash-public
RELIABILITY_DASH_PAGES_BRANCH=main
RELIABILITY_DASH_LIVE_URL=https://reliability.psfarms.co.ke
RELIABILITY_DASH_MAX_SNAPSHOT_AGE_MINUTES=45
